# 复制为 .env 使用；systemd 服务会读取它
# 管理后台密码 —— 必须设置，且强度要够
ADMIN_PASSWORD=change-me-to-a-long-random-string

# 监听端口（默认 3000）
PORT=3000

# ========================================
# 支付
# ========================================
# mock：返回模拟二维码，方便本地联调；live：真实调用微信/支付宝
PAY_MODE=mock

# 公网地址（用于拼接支付回调 URL）。推荐显式填写，避免代理头不可信。
# PUBLIC_BASE_URL=https://talk.xiaofamous.com

# ---------- 微信支付 Native V3 ----------
# WECHAT_APPID=
# WECHAT_MCH_ID=
# WECHAT_MCH_SERIAL_NO=
# WECHAT_API_V3_KEY=
# 选一种：私钥 PEM 直接内联（\n 保留为字面量）或指向文件
# WECHAT_MCH_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# WECHAT_MCH_PRIVATE_KEY_FILE=/home/andrew/xiaofamoustalk/secrets/apiclient_key.pem
# 平台证书（用于验签）；商户平台下载
# WECHAT_PLATFORM_CERT_FILE=/home/andrew/xiaofamoustalk/secrets/wechatpay_platform_cert.pem
# WECHAT_PLATFORM_CERT_SERIAL=

# ---------- 支付宝 当面付 ----------
# ALIPAY_APP_ID=
# ALIPAY_APP_PRIVATE_KEY_FILE=/home/andrew/xiaofamoustalk/secrets/alipay_app_key.pem
# ALIPAY_PUBLIC_KEY_FILE=/home/andrew/xiaofamoustalk/secrets/alipay_public_key.pem
# ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
